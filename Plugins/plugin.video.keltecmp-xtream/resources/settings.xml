<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<settings>


    <!-- ========================================== -->
    <!-- VIP - ACESSO COLABORADOR                   -->
    <!-- ========================================== -->
    <category label="KelTec VIP">
        <setting label="Acesso VIP — Colaboradores KelTec Media Play" type="lsep"/>
        <setting label="Autentique para acessar servidores e conteudos exclusivos" type="lsep"/>

        <setting type="sep"/>
        <setting label="Autenticacao" type="lsep"/>
        <setting label="Fazer login VIP" type="action"
                 action="RunPlugin(plugin://plugin.video.keltecmp-xtream/?mode=vip_login)"/>
        <setting label="Ver status da conta VIP" type="action"
                 action="RunPlugin(plugin://plugin.video.keltecmp-xtream/?mode=vip_status)"/>
        <setting label="Como adquirir acesso VIP" type="action"
                 action="RunPlugin(plugin://plugin.video.keltecmp-xtream/?mode=vip_contact)"/>

        <setting type="sep"/>
        <setting label="Dados internos VIP (nao editar manualmente)" type="lsep"/>
        <setting id="vip_username"   type="text" label="Usuario VIP"         default="" visible="false"/>
        <setting id="vip_plan"       type="text" label="Plano VIP"           default="" visible="false"/>
        <setting id="vip_expires_at" type="text" label="Validade VIP"        default="" visible="false"/>
        <setting id="vip_is_active"  type="bool" label="VIP Ativo"           default="false" visible="false"/>
    </category>



    <!-- ========================================== -->
    <!-- CONFIGURACOES DE SERVIDOR PRINCIPAL        -->
    <!-- ========================================== -->
    <category label="Configuracao do Servidor">
        <setting type="sep"/>
        <setting id="active_server" type="number" label="Servidor Ativo (ID)"                  default="0"    visible="true"/>
        <setting id="auto_fallback" type="bool"   label="Fallback automatico entre servidores" default="true"/>

        <setting label="Servidor Principal (Legado)" type="lsep"/>
        <setting label="Usado como fallback se nenhum servidor estiver ativo" type="lsep"/>

        <setting id="base_url"  type="text" label="URL do Servidor"   default="http://"/>
        <setting id="username"  type="text" label="Nome de Usuario"   default=""/>
        <setting id="password"  type="text" label="Senha"             default="" option="hidden"/>

        <setting type="sep"/>
        <setting label="Multiplos Servidores" type="lsep"/>
        <setting label="Configure ate 5 servidores diferentes" type="lsep"/>

        <setting id="server1_name" type="text" label="Servidor 1 - Nome"    default=""/>
        <setting id="server1_url"  type="text" label="Servidor 1 - URL"     default=""/>
        <setting id="server1_user" type="text" label="Servidor 1 - Usuario" default=""/>
        <setting id="server1_pass" type="text" label="Servidor 1 - Senha"   default="" option="hidden"/>

        <setting type="sep"/>
        <setting id="server2_name" type="text" label="Servidor 2 - Nome"    default=""/>
        <setting id="server2_url"  type="text" label="Servidor 2 - URL"     default=""/>
        <setting id="server2_user" type="text" label="Servidor 2 - Usuario" default=""/>
        <setting id="server2_pass" type="text" label="Servidor 2 - Senha"   default="" option="hidden"/>

        <setting type="sep"/>
        <setting id="server3_name" type="text" label="Servidor 3 - Nome"    default=""/>
        <setting id="server3_url"  type="text" label="Servidor 3 - URL"     default=""/>
        <setting id="server3_user" type="text" label="Servidor 3 - Usuario" default=""/>
        <setting id="server3_pass" type="text" label="Servidor 3 - Senha"   default="" option="hidden"/>

        <setting type="sep"/>
        <setting id="server4_name" type="text" label="Servidor 4 - Nome"    default=""/>
        <setting id="server4_url"  type="text" label="Servidor 4 - URL"     default=""/>
        <setting id="server4_user" type="text" label="Servidor 4 - Usuario" default=""/>
        <setting id="server4_pass" type="text" label="Servidor 4 - Senha"   default="" option="hidden"/>

        <setting type="sep"/>
        <setting id="server5_name" type="text" label="Servidor 5 - Nome"    default=""/>
        <setting id="server5_url"  type="text" label="Servidor 5 - URL"     default=""/>
        <setting id="server5_user" type="text" label="Servidor 5 - Usuario" default=""/>
        <setting id="server5_pass" type="text" label="Servidor 5 - Senha"   default="" option="hidden"/>
    </category>


    <!-- ========================================== -->
    <!-- MENU PRINCIPAL - VISIBILIDADE              -->
    <!-- ========================================== -->
    <category label="Menu Principal">
        <setting label="Escolha quais itens aparecem no menu principal" type="lsep"/>
        <setting label="Itens sempre visiveis: Servidor, Configuracoes" type="lsep"/>

        <setting type="sep"/>
        <setting label="Conteudo" type="lsep"/>
        <setting id="menu_show_doar"          type="bool" label="Mostrar Area de Doacoes"       default="false"/>
        <setting id="menu_show_account"       type="bool" label="Mostrar Informacoes da Conta"  default="false"/>
        <setting id="menu_show_search"        type="bool" label="Mostrar Pesquisa Global"        default="true"/>
        <setting id="menu_show_tv"            type="bool" label="Mostrar TV ao Vivo"             default="true"/>
        <setting id="menu_show_movies"        type="bool" label="Mostrar Filmes"                 default="true"/>
        <setting id="menu_show_series"        type="bool" label="Mostrar Series"                 default="true"/>
        <setting id="menu_show_pvrsync"       type="bool" label="Mostrar Sync IPTV + Proxy"       default="true"/>
        <setting id="menu_show_pvrguide"      type="bool" label="Mostrar Guia IPTV (Proxy)"         default="true"/>

        <setting type="sep"/>
        <setting label="Favoritos e Historico" type="lsep"/>
        <setting id="menu_show_favorites"     type="bool" label="Mostrar Favoritos"              default="true"/>
        <setting id="menu_show_history"       type="bool" label="Mostrar Ultimos Vistos"         default="true"/>

        <setting type="sep"/>
        <setting label="Trakt e Estatisticas" type="lsep"/>
        <setting id="menu_show_trakt"         type="bool" label="Mostrar Trakt.tv"                default="true"/>
        <setting id="menu_show_stats"         type="bool" label="Mostrar Dashboard de Estatisticas" default="true"/>

        <setting type="sep"/>
        <setting label="TMDB e Outros" type="lsep"/>
        <setting id="menu_show_tmdb"          type="bool" label="Mostrar Catalogo TMDB"          default="true"/>
        <setting id="menu_show_addons"        type="bool" label="Mostrar Meus Add-ons"           default="true"/>
        <setting id="menu_show_reload"        type="bool" label="Mostrar Atualizar Servidores"   default="false"/>
        <setting id="menu_show_parental"      type="bool" label="Mostrar Controle Parental"      default="true"/>
    </category>


    <!-- ========================================== -->
    <!-- TMDB - THE MOVIE DATABASE                  -->
    <!-- ========================================== -->
    <category label="TMDB - Metadados">
        <setting label="The Movie Database (TMDB)" type="lsep"/>
        <setting label="Adiciona posters, plots, ratings, elenco e mais!" type="lsep"/>

        <setting id="tmdb_enabled" type="bool" label="Habilitar TMDB" default="true"/>

        <setting type="sep"/>
        <setting label="Configuracao da API" type="lsep"/>
        <setting label="Obtenha sua API Key GRATIS em:" type="lsep"/>
        <setting label="https://www.themoviedb.org/settings/api" type="lsep"/>

        <setting id="tmdb_api_key" type="text" label="API Key" default="fc168650632c6597038cf7072a7c20da"/>

        <setting type="sep"/>
        <setting label="Opcoes de Metadados" type="lsep"/>

        <setting id="tmdb_language"    type="select" label="Idioma dos metadados"
                 values="Portugues (Brasil)|pt-BR|Portugues (Portugal)|pt-PT|Ingles|en-US|Espanhol|es-ES|Frances|fr-FR"
                 default="pt-BR"/>
        <setting id="tmdb_cache_days"  type="slider" label="Dias de cache do TMDB" default="7" range="1,1,30" option="int"/>
        <setting id="tmdb_use_fanart"  type="bool" label="Usar Fanart (fundos)"   default="true"/>
        <setting id="tmdb_use_cast"    type="bool" label="Mostrar elenco"          default="true"/>
        <setting id="tmdb_use_trailer" type="bool" label="Incluir trailers"        default="true"/>

        <setting type="sep"/>
        <setting label="Manutencao do Cache" type="lsep"/>
        <setting label="Limpar cache do TMDB" type="action"
                 action="RunPlugin(plugin://plugin.video.keltecmp-xtream/?mode=tmdb_clear_cache)"/>
    </category>


    <!-- ========================================== -->
    <!-- TRAKT.TV - SCROBBLE E WATCHLIST            -->
    <!-- ========================================== -->
    <category label="Trakt.tv">
        <setting label="Integracao com Trakt.tv" type="lsep"/>
        <setting label="Scrobble automatico, watchlist e historico sincronizado" type="lsep"/>

        <setting id="trakt_enabled" type="bool" label="Ativar integracao Trakt.tv" default="false"/>

        <setting type="sep"/>
        <setting label="Credenciais da API" type="lsep"/>
        <setting label="Crie sua aplicacao em: trakt.tv/oauth/applications/new" type="lsep"/>
        <setting label="Redirect URI obrigatorio: urn:ietf:wg:oauth:2.0:oob" type="lsep"/>

        <setting id="trakt_client_id"     type="text" label="Client ID"     default="7790012fe4684af427bc39b712a1050c4e813ed0edec72d46fbce0dd1dc4fedb"/>
        <setting id="trakt_client_secret" type="text" label="Client Secret" default="2f3bcc98ed7bc2f2a5a337267c1d4c0734886e6db8c220dd9d2a6e7156c716d1" option="hidden"/>

        <setting type="sep"/>
        <setting label="Autenticacao" type="lsep"/>
        <setting label="Conectar conta Trakt (abre tela de ativacao)" type="action"
                 action="RunPlugin(plugin://plugin.video.keltecmp-xtream/?mode=trakt_auth)"/>
        <setting label="Desconectar conta Trakt" type="action"
                 action="RunPlugin(plugin://plugin.video.keltecmp-xtream/?mode=trakt_disconnect)"/>

        <setting type="sep"/>
        <setting label="Acoes" type="lsep"/>
        <setting label="Ver minha Watchlist" type="action"
                 action="RunPlugin(plugin://plugin.video.keltecmp-xtream/?mode=trakt_watchlist)"/>
        <setting label="Sincronizar historico local com o Trakt agora" type="action"
                 action="RunPlugin(plugin://plugin.video.keltecmp-xtream/?mode=trakt_sync_history)"/>

        <setting type="sep"/>
        <setting label="Dados internos (nao editar manualmente)" type="lsep"/>
        <setting id="trakt_access_token"  type="text" label="Access Token"  default="" option="hidden" visible="false"/>
        <setting id="trakt_refresh_token" type="text" label="Refresh Token" default="" option="hidden" visible="false"/>
        <setting id="trakt_token_expiry"  type="text" label="Token Expiry"  default=""                 visible="false"/>
    </category>	


    <!-- ========================================== -->
    <!-- LEGENDAS (OpenSubtitles / Stremio)         -->
    <!-- ========================================== -->
    <category label="Legendas">
        <setting label="Legendas via Stremio/OpenSubtitles (sem API key)" type="lsep"/>

        <setting type="sep"/>
        <setting id="subtitles_enabled" type="bool" label="Ativar legendas" default="true"/>
        <setting id="legendasauto" type="bool" label="Baixar automaticamente ao reproduzir" default="true"/>
        <setting id="limparlegendas" type="bool" label="Limpar cache antes de baixar" default="true"/>

        <setting type="sep"/>
        <setting label="Idiomas" type="lsep"/>
        <setting id="idioma_legenda" type="select" label="Idioma preferido"
                  values="Portugues (Brasil)|Ingles|Espanhol"
                  default="0"/>
        <setting id="fallback_legenda" type="select" label="Idioma de fallback"
                  values="Nenhum|Portugues (Portugal)|Ingles|Espanhol"
                  default="0"/>

        <setting type="sep"/>
        <setting label="Manutencao" type="lsep"/>
        <setting label="Limpar cache de legendas agora" type="action"
                 action="RunPlugin(plugin://plugin.video.keltecmp-xtream/?mode=subtitles_clear_cache)"/>
    </category>

    <!-- ========================================== -->
    <!-- PLAYER E EPG                               -->
    <!-- ========================================== -->
    <category label="Player e EPG">
        <setting label="Configuracoes de Reproducao" type="lsep"/>

        <setting id="use_f4mtester"    type="bool" label="Usar proxy nativo para canais ao vivo" default="true"/>
        <setting id="use_keltec_proxy" type="bool" label="Usar proxy local para filmes e series" default="true"/>

        <setting type="sep"/>
        <setting label="Configuracoes do EPG" type="lsep"/>

        <setting id="enable_epg" type="bool" label="Ativar EPG (Guia de Programacao)" default="true"/>
        <setting id="epg_refresh_minutes" type="slider" label="Intervalo entre atualizacoes (minutos)" default="720" range="60,60,1440" option="int"/>
        <setting id="epg_offset_hours" type="slider" label="Ajuste manual de fuso horario (horas)" default="0" range="-12,1,12" option="int"/>

        <setting type="sep"/>
        <setting label="Proxy HTTP Externo" type="lsep"/>
        <setting label="Roteia requisicoes por proxy anonimo (pode deixar lento)" type="lsep"/>
        <setting id="proxy_http" type="bool" label="Ativar proxy externo (deprecado)" default="false" visible="false"/>

        <!-- IDs internos salvos automaticamente -->
        <setting id="active_server_name" type="text" label="Nome servidor ativo" default="" visible="false"/>
        <setting id="active_server_id"   type="text" label="ID servidor ativo"   default="" visible="false"/>
    </category>

    <!-- ========================================== -->
    <!-- PLUTO TV                                   -->
    <!-- ========================================== -->
    <category label="PVR (Proxy)">
        <setting label="IPTV via Proxy - Instancia 4" type="lsep"/>
        <setting label="Exporta canais do servidor IPTV para o PVR nativo (pvr.iptvsimple)" type="lsep"/>
        <setting label="A reproducao passa pelo proxy nativo (KPN)" type="lsep"/>

        <setting type="sep"/>
        <setting label="Sincronizar IPTV com o PVR agora" type="action"
                 action="RunPlugin(plugin://plugin.video.keltecmp-xtream/?mode=pvr_sync_server)"/>
    </category>

    <!-- ========================================== -->
    <!-- FAVORITOS DO SERVIDOR                      -->
    <!-- ========================================== -->
    <category label="Favoritos">
        <setting label="Canais, filmes e series marcados como favoritos" type="lsep"/>
        <setting label="Acesse seus favoritos no menu principal ou pelo botao direito nos itens" type="lsep"/>

        <setting type="sep"/>
        <setting label="Manutencao dos Favoritos" type="lsep"/>
        <setting label="Ver todos os favoritos" type="action"
                 action="RunPlugin(plugin://plugin.video.keltecmp-xtream/?mode=favorites_menu)"/>
        <setting label="Ver canais favoritos" type="action"
                 action="RunPlugin(plugin://plugin.video.keltecmp-xtream/?mode=favorites_list&amp;fav_type=live)"/>
        <setting label="Ver filmes favoritos" type="action"
                 action="RunPlugin(plugin://plugin.video.keltecmp-xtream/?mode=favorites_list&amp;fav_type=movie)"/>
        <setting label="Ver series favoritas" type="action"
                 action="RunPlugin(plugin://plugin.video.keltecmp-xtream/?mode=favorites_list&amp;fav_type=series)"/>
    </category>


    <!-- ========================================== -->
    <!-- ULTIMOS VISTOS - HISTORICO                 -->
    <!-- ========================================== -->
    <category label="Historico de Reproducao">
        <setting label="Registro dos ultimos itens assistidos" type="lsep"/>
        <setting label="Canais, filmes e series aparecem no menu Ultimos Vistos" type="lsep"/>

        <setting type="sep"/>
        <setting label="Manutencao do Historico" type="lsep"/>
        <setting label="Limpar todo o historico de reproducao" type="action"
                 action="RunPlugin(plugin://plugin.video.keltecmp-xtream/?mode=history_clear)"/>
        <setting label="Ver historico completo" type="action"
                 action="RunPlugin(plugin://plugin.video.keltecmp-xtream/?mode=history)"/>
    </category>


    <!-- ========================================== -->
    <!-- CONTROLE PARENTAL                          -->
    <!-- ========================================== -->
    <category label="Controle Parental">
        <setting label="Controle de Conteudo Adulto" type="lsep"/>
        <setting label="Protege conteudo [18+] com PIN numerico" type="lsep"/>

        <setting id="parental_enabled"        type="bool" label="Ativar Controle Parental"        default="true"/>
        <setting id="parental_pin"            type="text" label="PIN de Seguranca (4 digitos)"    default="0000" option="hidden"/>
        <setting id="parental_pin_configured" type="text" label="PIN ja configurado (interno)"    default="false" visible="false"/>

        <setting type="sep"/>
        <setting label="Palavras-chave bloqueadas (automatico):" type="lsep"/>
        <setting label="adult, xxx, 18+, porn, sexo, nude, hentai, lesbica, trans, hardcore" type="lsep"/>
    </category>

    <!-- ========================================== -->
    <!-- ESTATISTICAS DE VISUALIZACAO               -->
    <!-- ========================================== -->
    <category label="Estatisticas">
        <setting label="Dashboard de Visualizacoes" type="lsep"/>
        <setting label="Resumo de horas, generos, streaks e titulos mais assistidos" type="lsep"/>

        <setting type="sep"/>
        <setting label="Abrir Dashboard de Estatisticas" type="action"
                 action="RunPlugin(plugin://plugin.video.keltecmp-xtream/?mode=stats_dashboard)"/>
        <setting label="Ver historico completo de reproducao" type="action"
                 action="RunPlugin(plugin://plugin.video.keltecmp-xtream/?mode=history)"/>
    </category>


    <!-- ========================================== -->
    <!-- AVANCADO                                   -->
    <!-- ========================================== -->
    <category label="Avancado">
        <setting label="Opcoes Avancadas" type="lsep"/>

        <setting id="debug_mode" type="bool" label="Modo Debug (logs detalhados no Kodi)" default="false"/>
        <setting id="retry"      type="bool" label="Tentar novamente em falhas"            default="true"/>

        <setting type="sep"/>
        <setting label="Manutencao" type="lsep"/>
        <setting label="Limpar todos os caches (TMDB, EPG, Servidores, Trakt, DNS)" type="action"
                 action="RunPlugin(plugin://plugin.video.keltecmp-xtream/?mode=clear_all_cache)"/>
        <setting label="Forcar atualizacao de servidores remotos" type="action"
                 action="RunPlugin(plugin://plugin.video.keltecmp-xtream/?mode=reload_servers)"/>
        <setting label="Ver fontes dos servidores carregados" type="action"
                 action="RunPlugin(plugin://plugin.video.keltecmp-xtream/?mode=server_sources)"/>
        <setting label="Limpar cache TMDB" type="action"
                 action="RunPlugin(plugin://plugin.video.keltecmp-xtream/?mode=tmdb_clear_cache)"/>
        <setting label="Limpar cache Trakt.tv" type="action"
                 action="RunPlugin(plugin://plugin.video.keltecmp-xtream/?mode=trakt_clear_cache)"/>

        <!-- IDs internos Meus Add-ons -->
        <setting id="ag_1_enabled" type="bool" label="Grupo 1 habilitado" default="false" visible="false"/>
        <setting id="ag_2_enabled" type="bool" label="Grupo 2 habilitado" default="false" visible="false"/>
        <setting id="ag_3_enabled" type="bool" label="Grupo 3 habilitado" default="false" visible="false"/>
        <setting id="ag_4_enabled" type="bool" label="Grupo 4 habilitado" default="false" visible="false"/>
        <setting id="ag_5_enabled" type="bool" label="Grupo 5 habilitado" default="false" visible="false"/>
        <setting id="ag_1_name" type="text" label="Grupo 1 nome" default="" visible="false"/>
        <setting id="ag_2_name" type="text" label="Grupo 2 nome" default="" visible="false"/>
        <setting id="ag_3_name" type="text" label="Grupo 3 nome" default="" visible="false"/>
        <setting id="ag_4_name" type="text" label="Grupo 4 nome" default="" visible="false"/>
        <setting id="ag_5_name" type="text" label="Grupo 5 nome" default="" visible="false"/>
        <setting id="ag_1_addons" type="text" label="Grupo 1 addons" default="" visible="false"/>
        <setting id="ag_2_addons" type="text" label="Grupo 2 addons" default="" visible="false"/>
        <setting id="ag_3_addons" type="text" label="Grupo 3 addons" default="" visible="false"/>
        <setting id="ag_4_addons" type="text" label="Grupo 4 addons" default="" visible="false"/>
        <setting id="ag_5_addons" type="text" label="Grupo 5 addons" default="" visible="false"/>

        <!-- PVR (configuracao interna) -->
        <setting id="pvr_addon_control"   type="bool" label="PVR: Addon Control"     default="false" visible="false"/>
        <setting id="pvr_catchup_enabled" type="bool" label="PVR: Catchup"           default="false" visible="false"/>
        <setting id="pvr_catchup_days"    type="number" label="PVR: Dias Catchup"    default="3"     visible="false"/>
        <setting id="pvr_epg_refresh"     type="number" label="PVR: EPG Refresh (min)" default="60" visible="false"/>
        <setting id="pvr_epg_url"         type="text"   label="PVR: EPG URL"          default=""     visible="false"/>
        <setting id="pvr_osd_navigation"  type="bool"   label="PVR: OSD Navigation"   default="true" visible="false"/>
        <setting id="pvr_favorites_enabled" type="bool" label="PVR: Favoritos"         default="false" visible="false"/>

        <!-- Trakt interno -->
        <setting id="trakt_username" type="text" label="Trakt Username" default="" visible="false"/>
    </category>

</settings>